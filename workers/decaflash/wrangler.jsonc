{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "decaflash",
  "main": "src/index.js",
  "compatibility_date": "2026-04-08",
  "workers_dev": true,
  "r2_buckets": [
    {
      "binding": "DEBUG_ARTIFACTS",
      "bucket_name": "decaflash-debug-artifacts"
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  }
}
